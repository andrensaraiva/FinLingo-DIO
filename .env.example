# FinLingo — Environment Variables
# Copy this file to .env and fill in your API keys.

# ─── AI Provider ─────────────────────────────────────
# Choose "openai" or "gemini" (default: openai)
AI_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Google Gemini ───────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ─── Notes ───────────────────────────────────────────
# - The app works WITHOUT API keys using built-in fallback responses
# - Get an OpenAI key at https://platform.openai.com/api-keys
# - Get a Google AI key at https://aistudio.google.com/app/apikey
